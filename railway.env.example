# ==============================
# APP
# ==============================
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tu-app.up.railway.app

# ==============================
# FRONTEND / CORS
# ==============================
FRONTEND_URL=https://tu-app.up.railway.app
CORS_ALLOWED_ORIGIN=https://tu-app.up.railway.app

# ==============================
# JWT
# ==============================
JWT_SECRET=pon_aqui_un_jwt_secret_largo_y_seguro

# ==============================
# CLOUDINARY
# ==============================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=mascotas_webapp

# ==============================
# MYSQL / RAILWAY
# ==============================
MYSQLHOST=mysql.railway.internal
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=tu_password_mysql
MYSQLDATABASE=railway
MYSQL_URL=mysql://root:tu_password_mysql@mysql.railway.internal:3306/railway
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_general_ci

# ==============================
# EMAIL / BREVO SMTP
# ==============================
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=tu_usuario_smtp
MAIL_PASSWORD=tu_password_smtp
MAIL_FROM_ADDRESS=no-reply@tu-dominio.com
MAIL_FROM_NAME="Mascotas WebApp"
